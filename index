<!DOCTYPE html>
<html lang="pt-pt">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>QUEM DISSE ISSO? - Edição Cartoon Flash</title>
    <link href="https://fonts.googleapis.com/css2?family=Bangers&family=Comic+Neue:wght@700&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-paper: #f0f0f0;
            --border-thick: 5px solid #000;
            --comic-yellow: #ffde03;
            --comic-blue: #03a9f4;
            --comic-pink: #ff4081;
            --comic-green: #4caf50;
            --comic-orange: #ff9800;
            --shadow-flat: 8px 8px 0px #000;
        }

        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            background-color: var(--bg-paper);
            background-image: radial-gradient(#ccc 15%, transparent 16%);
            background-size: 15px 15px;
            font-family: 'Comic Neue', cursive;
            color: #000;
            display: flex;
            flex-direction: column;
            align-items: center;
            min-height: 100vh;
            padding: 20px;
            overflow-x: hidden;
            transition: background-color 0.2s;
        }

        /* --- EFEITO FLASH --- */
        #flash-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100vw;
            height: 100vh;
            pointer-events: none;
            z-index: 9999;
            opacity: 0;
        }

        @keyframes flash-wrong {
            0%, 33%, 66% { background-color: #ff0000; opacity: 0.8; }
            16%, 50%, 83% { background-color: #000000; opacity: 0.9; }
            100% { opacity: 0; }
        }

        @keyframes flash-correct {
            0%, 33%, 66% { background-color: #39ff14; opacity: 0.6; }
            16%, 50%, 83% { background-color: transparent; opacity: 0; }
            100% { opacity: 0; }
        }

        .flash-err { animation: flash-wrong 0.6s steps(1) 1; }
        .flash-hit { animation: flash-correct 0.6s steps(1) 1; }

        /* --- PLACAR CARTOON --- */
        header {
            width: 100%;
            max-width: 1000px;
            display: grid;
            grid-template-columns: 1fr auto 1fr;
            gap: 20px;
            margin-bottom: 40px;
            align-items: center;
            z-index: 10;
        }

        .player-box {
            background: white;
            border: var(--border-thick);
            padding: 15px;
            border-radius: 20px;
            box-shadow: var(--shadow-flat);
            text-align: center;
            transition: 0.3s;
        }

        .player-box.active {
            transform: scale(1.05) rotate(-2deg);
            background: var(--comic-yellow);
        }

        .player-name {
            background: transparent;
            border: none;
            font-family: 'Bangers', cursive;
            font-size: 1.8rem;
            width: 100%;
            text-align: center;
            outline: none;
            color: #000;
        }

        .player-score {
            font-size: 3rem;
            font-weight: 900;
            line-height: 1;
        }

        .vs-logo {
            font-family: 'Bangers', cursive;
            font-size: 2.5rem;
            background: #000;
            color: #fff;
            padding: 10px;
            border-radius: 50%;
            transform: rotate(15deg);
        }

        /* --- TABULEIRO DE CARTAS --- */
        .board {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
            gap: 25px;
            width: 100%;
            max-width: 1400px;
            padding-bottom: 150px;
        }

        .card {
            height: 380px;
            perspective: 1000px;
            transition: transform 0.3s, opacity 0.3s;
        }

        .card.locked {
            opacity: 0.2;
            filter: grayscale(0.8);
            pointer-events: none;
        }

        .card.active-theme {
            opacity: 1;
            filter: none;
            transform: scale(1.05);
            cursor: pointer;
        }

        .card-inner {
            position: relative;
            width: 100%;
            height: 100%;
            transition: transform 0.6s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            transform-style: preserve-3d;
        }

        .card.flipped .card-inner { transform: rotateY(180deg); }

        .card-front, .card-back {
            position: absolute;
            width: 100%;
            height: 100%;
            backface-visibility: hidden;
            border: var(--border-thick);
            border-radius: 25px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 20px;
            box-shadow: 5px 5px 0px #000;
        }

        .card-front { background: white; }
        .card-back { background: #fff; transform: rotateY(180deg); }

        .theme-icon { font-size: 6rem; margin-bottom: 10px; }
        .theme-label { 
            font-family: 'Bangers', cursive; 
            font-size: 1.8rem; 
            background: #000; 
            color: #fff; 
            padding: 5px 15px; 
            border-radius: 10px; 
        }

        .phrase-box {
            font-size: 1.2rem;
            text-align: center;
            font-weight: 800;
            margin-bottom: 15px;
            line-height: 1.2;
        }

        .options-box { display: none; flex-direction: column; gap: 8px; width: 100%; }
        .opt-btn {
            background: #fdfdfd;
            border: 3px solid #000;
            padding: 10px;
            border-radius: 15px;
            font-weight: bold;
            cursor: pointer;
            font-family: 'Comic Neue', cursive;
            transition: 0.2s;
        }
        .opt-btn:hover { background: var(--comic-blue); color: white; transform: translateX(5px); }
        .correct { background: var(--comic-green) !important; color: white; }
        .wrong { background: var(--comic-pink) !important; color: white; }

        /* --- DADO 3D --- */
        .dice-ui {
            position: fixed;
            bottom: 30px;
            right: 40px;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 15px;
            z-index: 100;
        }

        .dice-container {
            width: 100px;
            height: 100px;
            perspective: 600px;
            cursor: pointer;
        }

        .dice {
            width: 100%;
            height: 100%;
            position: relative;
            transform-style: preserve-3d;
            transition: transform 1.5s cubic-bezier(0.1, 0.7, 0.1, 1);
        }

        .face {
            position: absolute;
            width: 100px;
            height: 100px;
            background: white;
            border: 4px solid #000;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 3rem;
            box-shadow: inset 0 0 15px rgba(0,0,0,0.1);
            border-radius: 10px;
        }

        .face-1 { transform: rotateY(0deg) translateZ(50px); background: var(--comic-green); }
        .face-2 { transform: rotateY(180deg) translateZ(50px); background: var(--comic-pink); }
        .face-3 { transform: rotateY(90deg) translateZ(50px); background: var(--comic-blue); }
        .face-4 { transform: rotateY(-90deg) translateZ(50px); background: var(--comic-yellow); }
        .face-5 { transform: rotateX(90deg) translateZ(50px); background: var(--comic-orange); }
        .face-6 { transform: rotateX(-90deg) translateZ(50px); background: #fff; }

        .dice-bubble {
            background: #000;
            color: #fff;
            padding: 8px 15px;
            border-radius: 15px;
            font-family: 'Bangers', cursive;
            font-size: 1.3rem;
            white-space: nowrap;
        }

        .theme-Música { background: var(--comic-green) !important; }
        .theme-Filmes { background: var(--comic-pink) !important; }
        .theme-TV { background: var(--comic-blue) !important; }
        .theme-História { background: var(--comic-yellow) !important; }
        .theme-Internet { background: var(--comic-orange) !important; }

        @media (max-width: 768px) {
            header { grid-template-columns: 1fr 1fr; }
            .vs-logo { display: none; }
            .dice-ui { right: 20px; bottom: 20px; scale: 0.8; }
        }
    </style>
</head>
<body>

    <!-- Overlay para o efeito de flash -->
    <div id="flash-overlay"></div>

    <header>
        <div id="p1-box" class="player-box active">
            <input type="text" class="player-name" value="JOGADOR 1" maxlength="12">
            <div id="score-p1" class="player-score">0</div>
        </div>
        <div class="vs-logo">VS</div>
        <div id="p2-box" class="player-box">
            <input type="text" class="player-name" value="JOGADOR 2" maxlength="12">
            <div id="score-p2" class="player-score">0</div>
        </div>
    </header>

    <div class="board" id="game-board"></div>

    <div class="dice-ui">
        <div id="dice-msg" class="dice-bubble">RODA O DADO!</div>
        <div class="dice-container" onclick="rollDice()">
            <div id="dice" class="dice">
                <div class="face face-1">🎧</div>
                <div class="face face-2">🎬</div>
                <div class="face face-3">📺</div>
                <div class="face face-4">🏺</div>
                <div class="face face-5">🌐</div>
                <div class="face face-6">❓</div>
            </div>
        </div>
    </div>

    <script>
        const THEMES_CONFIG = [
            { name: "Música",    icon: "🎧", rotX: 0,   rotY: 0 },
            { name: "Filmes",    icon: "🎬", rotX: 0,   rotY: 180 },
            { name: "TV",        icon: "📺", rotX: 0,   rotY: -90 },
            { name: "História",  icon: "🏺", rotX: 0,   rotY: 90 },
            { name: "Internet",  icon: "🌐", rotX: -90, rotY: 0 },
            { name: "Sorte",     icon: "❓", rotX: 90,  rotY: 0 }
        ];

        const DATA = [
            { t: "Música", f: "The show must go on!", o: ["Freddie Mercury", "Elvis", "Madonna"], c: 0 },
            { t: "Música", f: "Imagine all the people...", o: ["John Lennon", "Bob Dylan", "Paul McCartney"], c: 0 },
            { t: "Música", f: "I'm a Barbie Girl, in a Barbie world.", o: ["Aqua", "Britney", "Spice Girls"], c: 0 },
            { t: "Música", f: "É uma casa portuguesa, com certeza!", o: ["Amália Rodrigues", "Tony Carreira", "Quim Barreiros"], c: 0 },
            { t: "Música", f: "Thriller!", o: ["Michael Jackson", "Prince", "James Brown"], c: 0 },
            { t: "Música", f: "Hello, it's me.", o: ["Adele", "Beyoncé", "Sia"], c: 0 },
            { t: "Música", f: "Like a Virgin.", o: ["Madonna", "Cyndi Lauper", "Pink"], c: 0 },
            { t: "Música", f: "O fado é o que eu sinto.", o: ["Ana Moura", "Mariza", "Amália Rodrigues"], c: 2 },
            { t: "Música", f: "Just dance, it's gonna be okay.", o: ["Lady Gaga", "Katy Perry", "Rihanna"], c: 0 },
            { t: "Música", f: "No woman, no cry.", o: ["Bob Marley", "Peter Tosh", "Jimmy Cliff"], c: 0 },
            { t: "Filmes", f: "I'll be back.", o: ["Terminator", "Rambo", "Robocop"], c: 0 },
            { t: "Filmes", f: "Que a força esteja contigo.", o: ["Luke Skywalker", "Darth Vader", "Yoda"], c: 0 },
            { t: "Filmes", f: "Meu precioso!", o: ["Gollum", "Harry Potter", "Frodo"], c: 0 },
            { t: "Filmes", f: "Vou fazer-lhe uma proposta impossível de recusar.", o: ["Padrinho", "Scarface", "Goodfellas"], c: 0 },
            { t: "Filmes", f: "Houston, temos um problema.", o: ["Apollo 13", "Interstellar", "Gravity"], c: 0 },
            { t: "Filmes", f: "Eu sou o Rei do Mundo!", o: ["Titanic", "Avatar", "Inception"], c: 0 },
            { t: "Filmes", f: "Bond. James Bond.", o: ["007", "Sherlock", "Jason Bourne"], c: 0 },
            { t: "Filmes", f: "Elementar, meu caro Watson.", o: ["Sherlock Holmes", "Poirot", "Batman"], c: 0 },
            { t: "Filmes", f: "Isto é Esparta!", o: ["Leonidas", "Maximus", "Achilles"], c: 0 },
            { t: "Filmes", f: "A vida é como uma caixa de chocolates.", o: ["Forrest Gump", "Big", "Cast Away"], c: 0 },
            { t: "TV", f: "Bazinga!", o: ["Sheldon", "Joey", "Barney"], c: 0 },
            { t: "TV", f: "Winter is coming.", o: ["Game of Thrones", "Vikings", "The Witcher"], c: 0 },
            { t: "TV", f: "How you doin'?", o: ["Joey", "Ross", "Chandler"], c: 0 },
            { t: "TV", f: "Eu sou aquele que bate à porta.", o: ["Walter White", "Tony Soprano", "Dexter"], c: 0 },
            { t: "TV", f: "A verdade está lá fora.", o: ["Arquivo X", "Stranger Things", "Dark"], c: 0 },
            { t: "TV", f: "D'oh!", o: ["Homer Simpson", "Peter Griffin", "Cartman"], c: 0 },
            { t: "TV", f: "Lá casa de papel.", o: ["Professor", "Berlim", "Tóquio"], c: 0 },
            { t: "TV", f: "Yada Yada Yada.", o: ["Seinfeld", "Friends", "The Office"], c: 0 },
            { t: "TV", f: "That's what she said.", o: ["Michael Scott", "Jim Halpert", "Dwight"], c: 0 },
            { t: "TV", f: "Vai ser legen... dário!", o: ["Barney Stinson", "Ted Mosby", "Marshall"], c: 0 },
            { t: "História", f: "Tenho um sonho.", o: ["MLK Jr", "Mandela", "Gandhi"], c: 0 },
            { t: "História", f: "Vim, vi, venci.", o: ["Júlio César", "Napoleão", "Alexandre"], c: 0 },
            { t: "História", f: "E no entanto, ela move-se.", o: ["Galileu", "Copérnico", "Newton"], c: 0 },
            { t: "História", f: "Penso, logo existo.", o: ["Descartes", "Kant", "Nietzsche"], c: 0 },
            { t: "História", f: "O Estado sou eu.", o: ["Luís XIV", "Napoleão", "Henrique VIII"], c: 0 },
            { t: "História", f: "Um pequeno passo para o homem...", o: ["Neil Armstrong", "Gagarin", "Buzz Aldrin"], c: 0 },
            { t: "História", f: "Só sei que nada sei.", o: ["Sócrates", "Platão", "Aristóteles"], c: 0 },
            { t: "História", f: "A imaginação é mais importante que o saber.", o: ["Einstein", "Tesla", "Edison"], c: 0 },
            { t: "História", f: "Sangue, suor e lágrimas.", o: ["Churchill", "Lincoln", "Roosevelt"], c: 0 },
            { t: "História", f: "Libertem o povo!", o: ["Afonso Henriques", "Mandela", "Guevara"], c: 0 },
            { t: "Internet", f: "Subscreve o canal e deixa o like!", o: ["YouTuber", "Político", "Professor"], c: 0 },
            { t: "Internet", f: "Link na bio!", o: ["Influencer", "Padeiro", "Médico"], c: 0 },
            { t: "Internet", f: "Isto vai viralizar.", o: ["Tiktoker", "Biólogo", "Arqueólogo"], c: 0 },
            { t: "Internet", f: "Fui cancelado.", o: ["Utilizador Web", "Passageiro", "Piloto"], c: 0 },
            { t: "Internet", f: "LOL.", o: ["Internauta", "Professor", "Juiz"], c: 0 },
            { t: "Internet", f: "O Wi-fi caiu!", o: ["Geração Z", "Geração X", "Paleolítico"], c: 0 },
            { t: "Internet", f: "Hashtag gratidão.", o: ["Instagrammer", "Pescador", "Advogado"], c: 0 },
            { t: "Internet", f: "Trollar é preciso.", o: ["Troll de Internet", "Mecânico", "Bombeiro"], c: 0 },
            { t: "Internet", f: "Isso é cringe.", o: ["Millennial", "Geração Z", "Boomer"], c: 1 },
            { t: "Internet", f: "Stonks!", o: ["Meme", "Banqueiro", "Economista"], c: 0 }
        ];

        let score = [0, 0];
        let turn = 0;
        let rolling = false;
        let activeTheme = null;

        function init() {
            const grid = document.getElementById('game-board');
            grid.innerHTML = '';
            const deck = [...DATA].sort(() => Math.random() - 0.5);

            deck.forEach((q) => {
                const config = THEMES_CONFIG.find(t => t.name === q.t);
                const card = document.createElement('div');
                card.className = `card locked theme-group-${q.t}`;
                card.dataset.theme = q.t;
                card.dataset.step = "0";

                card.innerHTML = `
                    <div class="card-inner">
                        <div class="card-front theme-${q.t}">
                            <div class="theme-icon">${config.icon}</div>
                            <div class="theme-label">${q.t}</div>
                        </div>
                        <div class="card-back">
                            <div class="phrase-box">"${q.f}"</div>
                            <div class="options-box">
                                ${q.o.map((opt, idx) => `
                                    <button class="opt-btn" onclick="checkAnswer(event, this, ${idx}, ${q.c})">${opt}</button>
                                `).join('')}
                            </div>
                        </div>
                    </div>
                `;
                card.onclick = (e) => flipCard(card, e);
                grid.appendChild(card);
            });
        }

        function rollDice() {
            if (rolling) return;
            rolling = true;
            const dice = document.getElementById('dice');
            const msg = document.getElementById('dice-msg');
            msg.innerText = "A GIRAR...";

            const targetIdx = Math.floor(Math.random() * 6);
            const theme = THEMES_CONFIG[targetIdx];
            
            const extra = 1800; 
            dice.style.transform = `rotateX(${theme.rotX + extra}deg) rotateY(${theme.rotY + extra}deg)`;

            setTimeout(() => {
                rolling = false;
                activeTheme = theme.name;
                msg.innerText = `JOGA: ${activeTheme.toUpperCase()}!`;
                updateBoard();
            }, 1500);
        }

        function updateBoard() {
            const cards = document.querySelectorAll('.card');
            cards.forEach(c => {
                c.classList.remove('active-theme', 'locked');
                if (activeTheme === "Sorte") {
                    if (c.dataset.step !== "3") c.classList.add('active-theme');
                } else if (c.dataset.theme === activeTheme && c.dataset.step !== "3") {
                    c.classList.add('active-theme');
                } else {
                    c.classList.add('locked');
                }
            });
        }

        function flipCard(card, e) {
            if (e.target.tagName === 'BUTTON' || rolling || !card.classList.contains('active-theme')) return;
            const step = parseInt(card.dataset.step);
            if (step === 0) {
                card.classList.add('flipped');
                card.dataset.step = "1";
            } else if (step === 1) {
                card.querySelector('.options-box').style.display = 'flex';
                card.dataset.step = "2";
            }
        }

        function triggerFlash(isCorrect) {
            const overlay = document.getElementById('flash-overlay');
            overlay.classList.remove('flash-hit', 'flash-err');
            
            // Forçar reflow para reiniciar animação
            void overlay.offsetWidth; 
            
            overlay.classList.add(isCorrect ? 'flash-hit' : 'flash-err');
        }

        function checkAnswer(e, btn, sel, cor) {
            e.stopPropagation();
            const card = btn.closest('.card');
            if (card.dataset.step === "3") return;
            card.dataset.step = "3";

            const isCorrect = sel === cor;
            triggerFlash(isCorrect);

            const btns = card.querySelectorAll('.opt-btn');
            if (isCorrect) {
                btn.classList.add('correct');
                score[turn]++;
            } else {
                btn.classList.add('wrong');
                btns[cor].classList.add('correct');
            }
            
            updateStats();
            
            setTimeout(() => {
                turn = turn === 0 ? 1 : 0;
                activeTheme = null;
                document.getElementById('p1-box').classList.toggle('active', turn === 0);
                document.getElementById('p2-box').classList.toggle('active', turn === 1);
                document.getElementById('dice-msg').innerText = `VEZ DO JOGADOR ${turn + 1}`;
                resetBoard();
            }, 1200);
        }

        function updateStats() {
            document.getElementById('score-p1').innerText = score[0];
            document.getElementById('score-p2').innerText = score[1];
        }

        function resetBoard() {
            document.querySelectorAll('.card').forEach(c => {
                c.classList.remove('active-theme');
                c.classList.add('locked');
            });
        }

        window.onload = init;
    </script>
</body>
</html>

